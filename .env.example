EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The places picker (autocomplete + details) requires the `places-search` edge
# function to have a Google Places API (New) key. This is a server-side function
# secret, NOT an EXPO_PUBLIC var — set it with:
#   supabase secrets set GOOGLE_PLACES_API_KEY=...
#
# The Places map (react-native-maps) uses Apple Maps on iOS via the default
# provider — no API key required. (Android would need a Google Maps key, but the
# app targets iOS only.)

# Native Google Sign In (Layer B) — needed for the Google OAuth button.
# iOS client ID: create an "iOS" OAuth client in Google Cloud Console for bundle ID com.daemi.app.
# Web client ID: create a "Web application" OAuth client (used by Supabase to exchange the ID token).
# Once set, replace the iosUrlScheme placeholder in app.json with the reversed iOS client ID
# (e.g. com.googleusercontent.apps.<your-ios-client-id>).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
