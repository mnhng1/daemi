EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The places picker (autocomplete + details) requires the `places-search` edge
# function to have a Google Places API (New) key. This is a server-side function
# secret, NOT an EXPO_PUBLIC var — set it with:
#   supabase secrets set GOOGLE_PLACES_API_KEY=...
#
# The Places map (react-native-maps) requires a SEPARATE, CLIENT-side Android
# Google Maps key. It is NOT an env var — it is embedded in the app bundle via
# app.json's react-native-maps plugin (`androidGoogleMapsApiKey`). Restrict it by
# Android package name (com.daemi.app) + signing SHA-1 in the Google Cloud
# console. It is distinct from the server-side GOOGLE_PLACES_API_KEY above.
# iOS uses Apple Maps and needs no key (default provider, no PROVIDER_GOOGLE).
