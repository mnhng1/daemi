EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# The places picker (autocomplete + details) requires the `places-search` edge
# function to have a Google Places API (New) key. This is a server-side function
# secret, NOT an EXPO_PUBLIC var — set it with:
#   supabase secrets set GOOGLE_PLACES_API_KEY=...
#
# The Places map (react-native-maps) requires a SEPARATE, CLIENT-side Android
# Google Maps key. Set it as a BUILD-TIME env var; app.config.js injects it into
# the react-native-maps plugin so the key is never committed to app.json:
#   ANDROID_MAPS_API_KEY=...
# Restrict it by Android package name (com.daemi.app) + signing SHA-1 in the
# Google Cloud console. It is distinct from the server-side GOOGLE_PLACES_API_KEY
# above. When unset, the Android map renders blank but the Places list still
# works (the map is an additive lens). iOS uses Apple Maps and needs no key
# (default react-native-maps provider, no PROVIDER_GOOGLE).
ANDROID_MAPS_API_KEY=
